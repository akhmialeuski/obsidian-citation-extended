{
  "name": "obsidian-citation-extended",
  "version": "0.6.0",
  "description": "Extended functionality to automatically search and insert citations from a Zotero library.",
  "main": "main.js",
  "scripts": {
    "dev": "rollup --config rollup.config.mjs -w",
    "build": "rollup --config rollup.config.mjs",
    "lint": "eslint .",
    "test": "jest",
    "bench": "jest --config jest.bench.config.cjs",
    "doc": "typedoc src/types.ts",
    "release": "standard-version",
    "prepare": "husky"
  },
  "standard-version": {
    "bumpFiles": [
      "manifest.json"
    ],
    "scripts": {
      "postbump": "node version-bump.mjs && git add manifest.json versions.json"
    }
  },
  "keywords": [],
  "author": "Anatol Khmialeuski",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-replace": "^5.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "eslint-plugin-prettier": "^5.5.4",
    "fast-check": "^3.0.0",
    "globals": "^16.5.0",
    "husky": "^9.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.2.0",
    "obsidian": "^1.10.3",
    "prettier": "^3.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-web-worker-loader": "^1.6.1",
    "ts-jest": "^29.1.0",
    "tslib": "^2.6.0",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "dependencies": {
    "@retorquere/bibtex-parser": "^6.4.19",
    "chokidar": "^3.5.3",
    "handlebars": "^4.7.7",
    "minisearch": "^7.2.0",
    "node-diff3": "^3.2.1",
    "open": "^8.4.2",
    "unicode2latex": "^3.0.3",
    "zod": "^3.22.0"
  },
  "lint-staged": {
    "*.ts": "eslint --fix",
    "*.json": "prettier --write"
  },
  "jest": {
    "roots": [
      "<rootDir>/tests",
      "<rootDir>/src"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.spec.ts"
    ],
    "moduleNameMapper": {
      "src/(.*)": "<rootDir>/src/$1"
    },
    "moduleFileExtensions": [
      "js",
      "ts",
      "d.ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/worker.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov"
    ]
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.53.3"
  }
}
